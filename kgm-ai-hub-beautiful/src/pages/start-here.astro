---
import Layout from '../components/Layout.astro';
const prompt = `You are helping me with work at an Australian automotive company. Before answering, ask me for any missing context you need. Keep your answer practical, concise and suitable for a professional internal audience.`;
---
<Layout title="Start Here | AI Hub">
  <section class="recipe">
    <div class="eyebrow">👋 Beginner · 4 min</div>
    <h1>Start here</h1>
    <p class="lead">Three rules: give context, keep the conversation going, and check important facts before using the answer.</p>
    <div class="steps">
      <div class="step"><h3>1. AI has no context</h3><p>Explain the company, audience, purpose, tone and expected output.</p></div>
      <div class="step"><h3>2. AI is not an authority</h3><p>It can make mistakes. Verify figures, links, policies and decisions.</p></div>
      <div class="step"><h3>3. Keep talking</h3><p>Ask it to make the answer shorter, clearer, more Australian, more executive, or more specific.</p></div>
      <div class="step"><h3>4. Ask for outcomes</h3><p>Do not ask “tell me about X”. Ask “compare X and recommend actions for Y audience”.</p></div>
    </div>
    <div class="panel"><h2>Starter prompt</h2><div class="prompt">{prompt}</div><button class="btn copy" data-copy={prompt}>Copy prompt</button></div>
  </section>
</Layout>
