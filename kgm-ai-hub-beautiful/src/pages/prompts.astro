---
import Layout from '../components/Layout.astro';
const prompts = [
['Improve my prompt',`Improve this prompt so it gives a better, more specific answer. Ask me for missing context before rewriting it.`],
['Summarise anything',`Summarise this in plain English. Then list action items, risks, decisions and open questions.`],
['Make it executive',`Rewrite this for a senior executive audience. Make it concise, structured and focused on decisions.`],
['Check for hallucinations',`Review your previous answer. Identify any claims that need verification, possible assumptions and sources I should check.`]
];
---
<Layout title="Prompt Library | AI Hub"><section class="section"><h2>Prompt Library</h2><p class="lead">A small set of prompts everyone can reuse.</p><div class="grid">{prompts.map(([title,p])=><div class="card"><h3>{title}</h3><p class="prompt" style="font-size:14px">{p}</p><button class="btn copy" data-copy={p}>Copy prompt</button></div>)}</div></section></Layout>
