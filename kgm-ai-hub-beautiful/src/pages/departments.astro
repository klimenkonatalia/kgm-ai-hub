---
import Layout from '../components/Layout.astro';
const departments = ['Sales','Product','Marketing','Finance','Accounts','Network Development','Logistics','Customer Support','Warranty','Technical Support','Parts','Aftersales','Executive'];
---
<Layout title="Departments | AI Hub"><section class="section"><h2>AI by department</h2><p class="lead">Role-specific ideas for practical work. These pages are placeholders for version 1.0.</p><div class="dept-grid">{departments.map((d)=><a class="dept" href={`/kgm-ai-hub/department-template/`}><strong>{d}</strong><p style="color:var(--muted);font-size:14px">Use cases, prompts and challenges.</p></a>)}</div></section></Layout>
