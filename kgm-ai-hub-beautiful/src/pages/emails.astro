---
import Layout from '../components/Layout.astro';
const prompt = `Draft a professional but friendly email in Australian English.

Audience: dealer principal
Situation: delivery of a vehicle has been delayed by one week due to a vessel schedule change
Tone: clear, calm, accountable
Length: under 150 words
Include: apology, reason, next steps and offer to help`;
---
<Layout title="Write Emails | AI Hub"><section class="recipe"><div class="eyebrow">✍️ Writing · 3 min</div><h1>Write clearer emails in half the time.</h1><p class="lead">Use AI for first drafts, tone changes, summaries and follow-ups. Always read before sending.</p><div class="panel"><h2>Prompt</h2><div class="prompt">{prompt}</div><button class="btn copy" data-copy={prompt}>Copy prompt</button></div></section></Layout>
