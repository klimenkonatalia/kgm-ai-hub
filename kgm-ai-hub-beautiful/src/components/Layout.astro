---
const { title = 'AI Hub @ KGM Australia', description = 'Practical AI recipes for everyday work.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${base}favicon.svg`} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <div class="noise"></div>
    <header class="site-header">
      <a class="brand" href={base}>
        <span class="brand-mark">AI</span>
        <span>AI Hub</span>
      </a>
      <nav class="nav">
        <a href={`${base}start-here/`}>Start here</a>
        <a href={`${base}everyday-ai/`}>Everyday AI</a>
        <a href={`${base}departments/`}>Departments</a>
        <a href={`${base}prompts/`}>Prompts</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div>
        <strong>Kevin says:</strong> “I am smart, but I still do not know what your dealer network looks like. Give me context.”
      </div>
    </footer>
    <script is:inline>
      document.addEventListener('click', async (event) => {
        const button = event.target.closest('[data-copy]');
        if (!button) return;
        const text = button.getAttribute('data-copy');
        await navigator.clipboard.writeText(text);
        const original = button.textContent;
        button.textContent = '✓ Copied';
        button.classList.add('copied');
        setTimeout(() => { button.textContent = original; button.classList.remove('copied'); }, 1300);
      });
    </script>
  </body>
</html>
